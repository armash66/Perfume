# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Ignore duplicate images folder (use frontend/public/images/ instead)
/images/

# Ignore WhatsApp zip files
*.zip

# Ignore inspection and temporary HTML files generated by tools
*_inspect.html
frontend/public/*_inspect.html

# Ignore temporary media/screenshots generated by tools
**/media__*.png

# Ignore environment variables
.env
.env.local

node_modules

# clerk configuration (can include secrets)
/.clerk/
